# Copy this file to .env and fill in your own values
# 火山引擎（Volcengine）TTS credentials — https://www.volcengine.com/
VOLCENGINE_APPID=your_app_id_here
VOLCENGINE_ACCESS_KEY=your_access_key_here
VOLCENGINE_SECRET_KEY=your_secret_key_here

# 豆包 LLM API key — https://www.volcengine.com/product/doubao
ARK_API_KEY=your_doubao_api_key_here

# Optional: WatchAgent server auth key (leave empty to disable)
WATCHAGENT_API_KEY=
